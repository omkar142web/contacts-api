<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>All Info</title>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;800&family=DM+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="css/home.css" />
  <style>
    .modal-overlay {
      display: none;
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(0,0,0,0.6);
      z-index: 1000;
      justify-content: center;
      align-items: center;
      backdrop-filter: blur(4px);
    }
    .modal-overlay.active {
      display: flex;
    }
    .modal-content {
      background: var(--bg, #fff);
      color: var(--text, #333);
      padding: 2rem;
      border-radius: 12px;
      width: 90%;
      max-width: 420px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.2);
      border: 1px solid rgba(255,255,255,0.05);
    }
    @media (prefers-color-scheme: dark) {
      .modal-content {
        --bg: #1e293b;
        --text: #f8fafc;
      }
    }
    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
    }
    .modal-header h2 {
      margin: 0;
      font-size: 1.25rem;
    }
    .close-btn {
      background: none;
      border: none;
      font-size: 1.5rem;
      cursor: pointer;
      color: inherit;
      opacity: 0.7;
    }
    .close-btn:hover {
      opacity: 1;
    }
    .form-group {
      margin-bottom: 1.25rem;
    }
    .form-group label {
      display: block;
      margin-bottom: 0.5rem;
      font-weight: 500;
      font-size: 0.9rem;
      color: inherit;
    }
    .form-group input {
      width: 100%;
      padding: 0.75rem;
      border: 1px solid var(--border, #ccc);
      border-radius: 6px;
      box-sizing: border-box;
      font-family: inherit;
      background: var(--input-bg, #fff);
      color: inherit;
      outline: none;
      transition: border-color 0.2s;
    }
    @media (prefers-color-scheme: dark) {
      .form-group input {
        --input-bg: #0f172a;
        --border: #334155;
      }
    }
    .form-group input:focus {
      border-color: #3b82f6;
    }
    .submit-btn {
      width: 100%;
      padding: 0.75rem;
      background: #3b82f6;
      color: white;
      border: none;
      border-radius: 6px;
      font-weight: 600;
      cursor: pointer;
      margin-top: 1rem;
      transition: background 0.2s;
      font-family: inherit;
    }
    .submit-btn:hover {
      background: #2563eb;
    }
    .submit-btn:disabled {
      background: #94a3b8;
      cursor: not-allowed;
    }
  </style>
</head>

<body>

  <div class="topbar">
    <h1>
      <span class="dot"></span>
      Share Info
    </h1>
    <button class="add-icon" id="openAddModalBtn">
      Add Data
    </button>
  </div>

  <div class="container">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Links / Data</th>
          <th>Email</th>
          <th>Actions</th>
        </tr>
      </thead>

      <tbody class="contactTable">
        <% if (data.length === 0) { %>
        <tr class="empty-row">
          <td colspan="4">
            <span>📭</span>
            No contacts yet.
          </td>
        </tr>
        <% } %>

        <% data.forEach((person) => { %>
        <tr>
          <td><%= person.name %></td>

          <% if (person.info?.includes(".") && !person.info.includes(" ")) { %>
          <td>
            <a href="<%= person.info.startsWith('http') ? person.info : 'https://' + person.info %>" target="_blank" rel="noopener noreferrer">
              <%= person.info %>
            </a>
          </td>
          <% } else { %>
          <td><%= person.info %></td>
          <% } %>

          <td><%= person.email %></td>

          <td>
            <button class="edit" onclick="window.location.href='update/<%= person._id %>'">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
              </svg>
              Edit
            </button>
            <button class="delete" onclick="DeleteFun('<%= person._id %>', this)">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3 6 5 6 21 6" />
                <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                <path d="M10 11v6" />
                <path d="M14 11v6" />
                <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
              </svg>
              Delete
            </button>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Add Modal -->
  <div id="addModal" class="modal-overlay">
    <div class="modal-content">
      <div class="modal-header">
        <h2>Add Info</h2>
        <button class="close-btn" id="closeAddModalBtn">&times;</button>
      </div>
      <form id="addForm">
        <div class="form-group">
          <label for="modal-name">Full Name</label>
          <input type="text" id="modal-name" name="name" required placeholder="e.g. Rahul Sharma" />
        </div>
        <div class="form-group">
          <label for="modal-email">Email Address</label>
          <input type="email" id="modal-email" name="email" required placeholder="rahul@example.com" />
        </div>
        <div class="form-group">
          <label for="modal-info">Links / Any Data</label>
          <input type="text" id="modal-info" name="info" required placeholder="e.g. website link, notes..." />
        </div>
        <button type="submit" class="submit-btn" id="submitAddBtn">Add Info</button>
      </form>
    </div>
  </div>

  <script>
    // Modal logic
    const modal = document.getElementById('addModal');
    const openBtn = document.getElementById('openAddModalBtn');
    const closeBtn = document.getElementById('closeAddModalBtn');
    const addForm = document.getElementById('addForm');
    const submitBtn = document.getElementById('submitAddBtn');
    const tbody = document.querySelector('.contactTable');

    openBtn.addEventListener('click', () => {
      modal.classList.add('active');
    });

    closeBtn.addEventListener('click', () => {
      modal.classList.remove('active');
    });

    window.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.classList.remove('active');
      }
    });

    addForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const name = addForm.name.value.trim();
      const email = addForm.email.value.trim();
      const info = addForm.info.value.trim();

      if (!name || !email || !info) return;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Adding...';

      try {
        const response = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, info })
        });

        if (!response.ok) throw new Error('Failed to add data');
        const result = await response.json();
        const newId = result.addedData.insertedId;

        // Remove empty state if present
        const emptyRow = tbody.querySelector('.empty-row');
        if (emptyRow) emptyRow.remove();

        // Create new row
        const tr = document.createElement('tr');
        
        let infoHtml = `<td>${info}</td>`;
        if (info.includes(".") && !info.includes(" ")) {
          const href = info.startsWith('http') ? info : 'https://' + info;
          infoHtml = `<td><a href="${href}" target="_blank" rel="noopener noreferrer">${info}</a></td>`;
        }

        tr.innerHTML = `
          <td>${name}</td>
          ${infoHtml}
          <td>${email}</td>
          <td>
            <button class="edit" onclick="window.location.href='update/${newId}'">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
              </svg>
              Edit
            </button>
            <button class="delete" onclick="DeleteFun('${newId}', this)">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3 6 5 6 21 6" />
                <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                <path d="M10 11v6" />
                <path d="M14 11v6" />
                <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
              </svg>
              Delete
            </button>
          </td>
        `;

        tbody.insertBefore(tr, tbody.firstChild);

        // Reset and close modal
        addForm.reset();
        modal.classList.remove('active');
        
      } catch (err) {
        console.error(err);
        alert('An error occurred while adding contact');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Add Contact';
      }
    });

    // ! delete function..
    async function DeleteFun(id, btn) {
      try {
        const response = await fetch(`${id}`, {
          method: 'delete'
        });

        if (!response.ok) {
          throw new Error('Network response was not ok');
        }

        const row = btn.closest('tr');
        row.style.transition = 'opacity 0.25s ease, transform 0.25s ease';
        row.style.opacity = '0';
        row.style.transform = 'translateX(12px)';
        setTimeout(() => row.remove(), 260);

      } catch (err) {
        console.error(err);
      }
    }
  </script>

</body>

</html>