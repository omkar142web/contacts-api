<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/update.css" />
</head>

<body>
  <h1><%= title %></h1>

  <form>
    <div>
      <label for="name">Full Name</label>
      <input type="text" id="name" name="name" placeholder="e.g. Rahul Sharma" <%= person?.name ? `value=${person.name}` : "" %> required />
    </div>

    <div>
      <label for="email">Email Address</label>
      <input type="email" id="email" name="email" placeholder="rahul@example.com" <%= person?.email ? `value=${person.email}` : "" %> required />
    </div>

    <div>
      <label for="phone">Phone Number</label>
      <input type="tel" id="phone" name="phone" placeholder="91000 00000" <%= person?.number ? `value=${person.number}` : "" %> required />
    </div>

    <div>
      <button type="submit">
        <!-- checkmark icon -->
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6 9 17l-5-5" />
        </svg>
        <%= buttonText %>
      </button>
      <a href="/api/contacts/" class="btn">
        <!-- list icon -->
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="8" y1="6" x2="21" y2="6" />
          <line x1="8" y1="12" x2="21" y2="12" />
          <line x1="8" y1="18" x2="21" y2="18" />
          <line x1="3" y1="6" x2="3.01" y2="6" />
          <line x1="3" y1="12" x2="3.01" y2="12" />
          <line x1="3" y1="18" x2="3.01" y2="18" />
        </svg>
        All Contacts
      </a>
    </div>
  </form>

  <% if (title != 'Add Contact') {%>
  <script>
    let form = document.querySelector("form");
    let inputs = form.querySelectorAll("input");

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const btn = form.querySelector("button[type='submit']");

      for (let input of inputs) {
        if (!input.value?.trim()) {
          alert("Please fill all fields");
          input.focus();
          return;
        }
      }

      try {
        btn.disabled = true;
        btn.innerHTML = `
            <span style="
              display: inline-flex;
              animation: spin 0.7s linear infinite;
              transform-origin: center;
            ">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12a9 9 0 1 1-6.22-8.56"/>
              </svg>
            </span>
            Updating…
          `;

        const response = await fetch(`/api/contacts/<%= person._id %>`, {
          method: "PUT",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            name: form.name.value.trim(),
            email: form.email.value.trim(),
            number: form.phone.value.trim(),
          }),
        });

        if (!response.ok) {
          throw new Error(data.message || "Update failed");
        }

        await new Promise((resolve) => setTimeout(resolve, 700));

        window.location.href = "/api/contacts/";
      } catch (err) {
        console.error(err);
        alert(err.message);
      } finally {
        btn.disabled = false;
        btn.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 6 9 17l-5-5"/>
            </svg>
            Update Contact
          `;
      }
    });
  </script>
  <% } else {%>
  <script>
    form = document.querySelector("form");
    inputs = form.querySelectorAll("input");

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const btn = form.querySelector("button[type='submit']");

      for (let input of inputs) {
        if (!input.value?.trim()) {
          alert("Please fill all fields");
          input.focus();
          return;
        }
      }

      try {
        btn.disabled = true;
        btn.innerHTML = `
            <span style="
              display: inline-flex;
              animation: spin 0.7s linear infinite;
              transform-origin: center;
            ">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12a9 9 0 1 1-6.22-8.56"/>
              </svg>
            </span>
            Adding…
          `;

        const response = await fetch(`/api/contacts/`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            name: form.name.value.trim(),
            email: form.email.value.trim(),
            number: form.phone.value.trim(),
          }),
        });

        if (!response.ok) {
          throw new Error(data.message || "Failed to add contact");
        }

        await new Promise((resolve) => setTimeout(resolve, 700));

        window.location.href = "/api/contacts/";
      } catch (err) {
        console.error(err);
        alert(err.message);
      } finally {
        btn.disabled = false;
        btn.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 6 9 17l-5-5"/>
            </svg>
            Add Contact
          `;
      }
    });
  </script>
  <% } %>
</body>

</html>