<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>All Contacts</title>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/home.css" />
  <style>
    a {
      color: blue;
      text-decoration: underline;
    }
  </style>
</head>

<body>
  <h1>All Contacts</h1>
  <div class="addContact">
    <button class="add-icon" onclick="window.location.href='add'">
      Add Contact
    </button>
  </div>
  <div class="container">

    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Number / Links</th>
          <th>Actions</th>
        </tr>
      </thead>

      <tbody class="contactTable">
        <% data.forEach((person) => { %>
        <tr>
          <td><%= person.name %></td>
          <td><%= person.email %></td>
          <% if (person.number?.includes(".")) { %>
          <td><a href="<%= person.number %>"><%= person.number %></a></td>
          <% } else { %>
          <td><%= person.number %></td>
          <% } %>
          <td>
            <button class="edit" onclick="window.location.href='update/<%= person._id %>'">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
              </svg>
              Edit
            </button>
            <button class="delete" onclick="DeleteFun('<%= person._id %>', this)">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3 6 5 6 21 6" />
                <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                <path d="M10 11v6" />
                <path d="M14 11v6" />
                <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
              </svg>
              Delete
            </button>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <script>
    // ! delete function..
    async function DeleteFun(id, btn) {
      try {
        const response = await fetch(
          `${id}`, {
            method: 'delete',
          })

        if (!response.ok) {
          throw new Error('Network response was not ok');
        }
        btn.closest('tr').remove()

      } catch (err) {
        console.error(err)
      }
    }
  </script>
</body>

</html>